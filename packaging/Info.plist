<?xml version="1.0" encoding="UTF-8"?>
<!--
  Описание бандла macOS. Собирается в Savio.app/Contents/ на CI.

  `LSFileQuarantineEnabled` здесь намеренно отсутствует. С ним macOS вешает
  атрибут карантина на все файлы, которые создаёт приложение, — включая
  скачанные им yt-dlp и ffmpeg. Они не нотаризованы, поэтому Gatekeeper
  запретил бы их запуск, а обойти это для файла в глубине
  ~/Library/Application Support пользователь практически не может.
-->
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>savio</string>
    <key>CFBundleIdentifier</key>
    <string>io.github.cholakhyanerik.savio</string>
    <key>CFBundleName</key>
    <string>Savio</string>
    <!-- Имя без расширения: macOS сама добавит `.icns`.
         Файл собирается на CI из packaging/savio.png. -->
    <key>CFBundleIconFile</key>
    <string>savio</string>
    <key>CFBundleDisplayName</key>
    <string>Savio</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>0.1.0</string>
    <!-- Ниже 11.0 универсальный бинарник с arm64-половиной не имеет смысла. -->
    <key>LSMinimumSystemVersion</key>
    <string>11.0</string>
    <key>NSHighResolutionCapable</key>
    <true/>
</dict>
</plist>
